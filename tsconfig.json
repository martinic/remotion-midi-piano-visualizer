{
    "compilerOptions": {
        "target": "ES2022",
        "module": "ES2022",
        "jsx": "react-jsx",
        "outDir": "./dist",
        "strict": true,
        "noEmit": true,
        "lib": ["ES2022", "DOM"],
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "moduleResolution": "bundler",
        "resolveJsonModule": true
    }
}
