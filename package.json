{
    "name": "remotion-midi-piano-visualizer",
    "version": "2.0.0",
    "description": "A MIDI piano visualizer built with Remotion",
    "scripts": {
        "start": "npx remotion studio",
        "build": "node src/api/parseMidiToJson.js && npx remotion render src/index.ts PianoComposition out.mp4",
        "parse-midi": "node src/api/parseMidiToJson.js",
        "get-info": "node src/api/getInfo.js"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/martinic/remotion-midi-piano-visualizer.git"
    },
    "license": "GPL-2.0-or-later",
    "dependencies": {
        "@remotion/cli": "4.0.242",
        "@tonejs/midi": "^2.0.28",
        "react": "^18.3.1",
        "react-dom": "^18.3.1",
        "react-piano": "^3.1.3",
        "remotion": "4.0.242"
    },
    "devDependencies": {
        "@types/react": "^18.3.12",
        "typescript": "^5.7.0"
    }
}
